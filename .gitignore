.gitignore
# =========================
# Secrets and local config
# =========================
appsettings.Development.json
appsettings.Local.json
secrets.json

# Keep this only if your real appsettings values are generated locally
# appsettings.json

# =========================
# .NET / C#
# =========================
**/bin/
**/obj/
*.user
*.suo
*.userosscache
*.sln.docstates

# Rider / ReSharper
.idea/
*.DotSettings.user

# =========================
# Node / Vite / Frontend
# =========================
**/node_modules/
**/dist/
**/dist-ssr/
**/.vite/
**/*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# =========================
# Python
# =========================
**/__pycache__/
*.py[cod]
*.pyd
*.pyo
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# =========================
# OS / editor files
# =========================
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json
*.swp
*.tmp
.env*

# =========================
# Media and generated outputs
# =========================
*.mp4
PoseDetection/PoseDetectionResults/*
PoseDetection/temp/*
